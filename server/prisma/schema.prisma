datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int              @id @default(autoincrement())
  googleId  String           @unique
  email     String           @unique
  name      String
  picture   String?
  rating    Int              @default(1500)
  createdAt DateTime         @default(now())
  attempts  PuzzleAttempt[]
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model Puzzle {
  id              Int              @id @default(autoincrement())
  puzzleId        String           @unique
  fen             String
  moves           String
  rating          Int
  ratingDeviation Int
  popularity      Int
  nbPlays         Int
  themes          String
  gameUrl         String
  openingTags     String
  attempts        PuzzleAttempt[]

  @@index([rating])
}

model PuzzleAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int
  puzzleId  Int
  correct    Boolean
  userRating Int?
  createdAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  puzzle    Puzzle   @relation(fields: [puzzleId], references: [id])
}