datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model Puzzle {
  id              Int    @id @default(autoincrement())
  puzzleId        String @unique
  fen             String
  moves           String
  rating          Int
  ratingDeviation Int
  popularity      Int
  nbPlays         Int
  themes          String
  gameUrl         String
  openingTags     String
}